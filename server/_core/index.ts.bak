      await updateStatus(id, { name, color, bgColor, ativo } as any);
      return res.json({ success: true });
    } catch (err) {
      console.error("[REST UPDATE STATUS]", err);
      return res.status(500).json({ error: "Erro ao atualizar status" });
    }
  });

  app.delete("/api/statuses/:id", async (req, res) => {
    try {
      const id = parseInt(req.params.id);
      await deleteStatus(id);
      return res.json({ success: true });
    } catch (err) {
      console.error("[REST DELETE STATUS]", err);
      return res.status(500).json({ error: "Erro ao deletar status" });
    }
  });

  // ─── Departments REST endpoints ──────────────────────────────────────────────
  app.post("/api/departments/create", async (req, res) => {
    try {
      const { name } = req.body;
      if (!name) return res.status(400).json({ error: "Nome é obrigatório" });
